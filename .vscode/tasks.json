{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run gerarCatalogo",
      "type": "shell",
      "command": "npx",
      "args": ["ts-node/esm", "gerarCatalogo.ts"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run index.ts",
      "type": "shell",
      "command": "npm",
      "args": ["start"],
      "group": {
        "kind": "build"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
