{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2020",
    "moduleResolution": "Node16",

    "outDir": "dist",

    "types": ["node"],
    "lib": ["ES2020", "DOM"],

    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },

  "include": ["*.ts"],

  "exclude": [
    "node_modules",
    "dist"
  ]
}